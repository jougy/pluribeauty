---

<BaseLayout 
  title="LOQK | Descobrir" 
  description="Encontre os melhores profissionais de beleza perto de voce."
>
  <div class="px-4 pt-12 pb-6 flex flex-col gap-6">
    <header>
      <h1 class="text-3xl font-display text-[var(--soft-black)] mb-2">LOQK</h1>
      <p class="text-sm text-[var(--warm-brown)]">Encontre seu profissional ideal.</p>
    </header>

    <!-- Search Section -->
    <section class="flex flex-col gap-4">
      <div class="relative">
        <input 
          type="text" 
          placeholder="Buscar servico ou profissional..." 
          class="w-full bg-[var(--off-white)] border border-[var(--sand)] rounded-2xl py-3 px-4 pl-12 focus:outline-none focus:ring-1 focus:ring-[var(--terracotta)]"
        />
        <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-3.5 w-5 h-5 text-[var(--warm-brown)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </div>
      
      <div class="flex items-center gap-4">
        <span class="text-sm font-medium text-[var(--soft-black)] whitespace-nowrap">Raio (km):</span>
        <input type="range" min="1" max="50" value="10" class="w-full accent-[var(--terracotta)]" />
        <span class="text-xs text-[var(--warm-brown)] w-8">10km</span>
      </div>
    </section>

    <!-- Categories Grid -->
    <section>
      <div class="flex justify-between items-end mb-4">
        <h2 class="text-xl font-display">Especialidades</h2>
      </div>
      <div class="grid grid-cols-3 min-[400px]:grid-cols-4 sm:grid-cols-5 md:grid-cols-6 lg:grid-cols-8 gap-3">
        {categories.map((cat) => (
          <a href={`/ListaProfissionais?category=${cat.name.toLowerCase()}`} class={`relative w-full aspect-square rounded-2xl overflow-hidden shadow-[var(--shadow-card)] transition-transform hover:-translate-y-1 active:scale-[0.95] ${cat.color} flex flex-col items-center justify-center p-2`}>
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            <div class="relative z-10 w-10 h-10 rounded-full bg-[var(--off-white)]/20 backdrop-blur-sm mb-2 flex items-center justify-center border border-[var(--off-white)]/30">
              <Fragment set:html={cat.svg} />
            </div>
            <h3 class="relative text-[var(--off-white)] font-display text-[11px] min-h-[30px] flex items-center justify-center font-medium tracking-wide z-10 text-center leading-tight [word-spacing:-2px]">{cat.name}</h3>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
