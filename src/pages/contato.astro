---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contato - Pluri Beauty"
  description="Entre em contato com a equipe Pluri Beauty."
>
  <section class="pt-32 pb-16 bg-gradient-elegant">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <span class="editorial-label">Contato</span>
        <h1 class="mt-4 magazine-headline text-foreground">Vamos <span class="italic text-primary">conversar?</span></h1>
        <p class="mt-6 text-lg text-muted-foreground">Duvidas, sugestoes, parcerias ou so um oi.</p>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-24">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 max-w-5xl mx-auto">
        <div>
          <span class="editorial-label">Onde nos encontrar</span>
          <h2 class="mt-4 font-display text-3xl font-medium text-foreground mb-8">Escolha o canal que preferir.</h2>

          <div class="space-y-6">
            <a href="mailto:contato@pluri.beauty" class="group flex items-center gap-4 p-4 rounded-lg border border-border bg-card hover:border-primary hover:shadow-[var(--shadow-soft)] transition-all duration-300">
              <div>
                <p class="text-xs text-muted-foreground uppercase tracking-wide">E-mail</p>
                <p class="text-foreground font-medium">contato@pluri.beauty</p>
              </div>
            </a>
            <a href="https://instagram.com/pluri.beauty" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 p-4 rounded-lg border border-border bg-card hover:border-primary hover:shadow-[var(--shadow-soft)] transition-all duration-300">
              <div>
                <p class="text-xs text-muted-foreground uppercase tracking-wide">Instagram</p>
                <p class="text-foreground font-medium">@pluri.beauty</p>
              </div>
            </a>
            <a href="https://linkedin.com/company/pluri-beauty" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 p-4 rounded-lg border border-border bg-card hover:border-primary hover:shadow-[var(--shadow-soft)] transition-all duration-300">
              <div>
                <p class="text-xs text-muted-foreground uppercase tracking-wide">LinkedIn</p>
                <p class="text-foreground font-medium">Pluri Beauty</p>
              </div>
            </a>
          </div>

          <div class="mt-10 p-6 rounded-lg bg-secondary">
            <p class="text-sm text-muted-foreground">Localizacao</p>
            <p class="text-foreground mt-2">100% remoto, conectando o Brasil inteiro.</p>
          </div>
        </div>

        <div>
          <form data-toast-message="Mensagem enviada! Responderemos em breve." class="beauty-card">
            <h2 class="font-display text-2xl font-medium text-foreground mb-8">Envie uma mensagem</h2>
            <div class="space-y-6">
              <div><label for="nome" class="label">Nome</label><input id="nome" class="input mt-2" required /></div>
              <div><label for="email" class="label">E-mail</label><input id="email" type="email" class="input mt-2" required /></div>
              <div><label for="assunto" class="label">Assunto</label><input id="assunto" class="input mt-2" required /></div>
              <div><label for="mensagem" class="label">Mensagem</label><textarea id="mensagem" rows="5" class="textarea mt-2" required></textarea></div>
              <button type="submit" class="btn-hero w-full">Enviar mensagem</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
