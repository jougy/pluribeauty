---
const year = new Date().getFullYear();
---

<footer class="bg-secondary border-t border-border">
  <div class="container mx-auto px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <div class="lg:col-span-1">
        <a href="/" class="font-display text-2xl font-semibold text-foreground">Pluri Beauty</a>
        <p class="mt-4 text-sm text-muted-foreground leading-relaxed">
          Conectando clientes e profissionais de beleza com simplicidade, confianca e elegancia.
        </p>
      </div>

      <div>
        <h4 class="editorial-label mb-6">Navegacao</h4>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm text-muted-foreground hover:text-primary transition-colors duration-300">Inicio</a></li>
          <li><a href="/beta" class="text-sm text-muted-foreground hover:text-primary transition-colors duration-300">Beta</a></li>
          <li><a href="/sobre" class="text-sm text-muted-foreground hover:text-primary transition-colors duration-300">Sobre</a></li>
          <li><a href="/contato" class="text-sm text-muted-foreground hover:text-primary transition-colors duration-300">Contato</a></li>
        </ul>
      </div>

      <div>
        <h4 class="editorial-label mb-6">Parcerias</h4>
        <ul class="space-y-3">
          <li><a href="/apoiadores" class="text-sm text-muted-foreground hover:text-primary transition-colors duration-300">Seja Apoiador</a></li>
          <li><a href="/patrocinadores" class="text-sm text-muted-foreground hover:text-primary transition-colors duration-300">Patrocinio</a></li>
        </ul>
      </div>

      <div>
        <h4 class="editorial-label mb-6">Conecte-se</h4>
        <div class="flex gap-4">
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-muted flex items-center justify-center text-muted-foreground hover:bg-primary hover:text-primary-foreground transition-all duration-300" aria-label="Instagram">IG</a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-muted flex items-center justify-center text-muted-foreground hover:bg-primary hover:text-primary-foreground transition-all duration-300" aria-label="LinkedIn">IN</a>
          <a href="mailto:contato@pluri.beauty" class="w-10 h-10 rounded-full bg-muted flex items-center justify-center text-muted-foreground hover:bg-primary hover:text-primary-foreground transition-all duration-300" aria-label="Email">@</a>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-border/50">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-xs text-muted-foreground">© {year} Pluri Beauty. Todos os direitos reservados.</p>
        <p class="text-xs text-muted-foreground">Feito com carinho para transformar a beleza</p>
      </div>
    </div>
  </div>
</footer>
