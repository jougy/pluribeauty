---
import BottomNav from '../components/BottomNav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  showBottomNav?: boolean;
}

const { title, description, showBottomNav = true } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAF9F6" />
    <link rel="icon" type="image/png" sizes="32x32" href="/public/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/public/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
  </head>
  <body class="bg-[var(--off-white)] text-[var(--soft-black)]">
    <main class={`min-h-screen ${showBottomNav ? 'pb-20' : ''}`}>
      <slot />
    </main>
    
    {showBottomNav && <BottomNav currentPath={currentPath} />}

    <div id="toast" class="toast"></div>

    <script>
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const openLabel = document.getElementById('menu-icon-open');
      const closeLabel = document.getElementById('menu-icon-close');
      const toast = document.getElementById('toast');

      function updateHeader() {
        if (!header) return;
        if (window.scrollY > 20) {
          header.classList.add('bg-background/90', 'backdrop-blur-md', 'border-b', 'border-border/50', 'shadow-[var(--shadow-soft)]');
        } else {
          header.classList.remove('bg-background/90', 'backdrop-blur-md', 'border-b', 'border-border/50', 'shadow-[var(--shadow-soft)]');
        }
      }

      function closeMenu() {
        if (!mobileMenu) return;
        mobileMenu.classList.add('hidden');
        openLabel?.classList.remove('hidden');
        closeLabel?.classList.add('hidden');
      }

      function showToast(message) {
        if (!toast) return;
        toast.textContent = message;
        toast.classList.add('show');
        window.setTimeout(() => toast.classList.remove('show'), 2400);
      }

      updateHeader();
      window.addEventListener('scroll', updateHeader);

      menuToggle?.addEventListener('click', () => {
        if (!mobileMenu) return;
        const isHidden = mobileMenu.classList.contains('hidden');
        mobileMenu.classList.toggle('hidden');
        openLabel?.classList.toggle('hidden', isHidden);
        closeLabel?.classList.toggle('hidden', !isHidden);
      });

      mobileMenu?.querySelectorAll('a').forEach((el) => el.addEventListener('click', closeMenu));

      document.querySelectorAll('form[data-toast-message]').forEach((form) => {
        form.addEventListener('submit', (event) => {
          event.preventDefault();
          const message = form.getAttribute('data-toast-message') || 'Enviado com sucesso';
          showToast(message);
          form.reset();
        });
      });

      document.querySelectorAll('[data-copy-text]').forEach((el) => {
        el.addEventListener('click', async () => {
          const text = el.getAttribute('data-copy-text');
          if (!text) return;
          try {
            await navigator.clipboard.writeText(text);
            showToast('Chave Pix copiada!');
          } catch {
            showToast('Nao foi possivel copiar automaticamente');
          }
        });
      });
    </script>
  </body>
</html>
