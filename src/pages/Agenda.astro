---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="LOQK | Minha Agenda" 
  description="Seus agendamentos LOQK"
>
  <div class="px-4 pt-12 pb-6 flex flex-col gap-6">
    <header>
      <h1 class="text-3xl font-display text-[var(--soft-black)] mb-2">Agenda</h1>
    </header>

    <div class="flex border-b border-[var(--sand)] text-sm font-medium mb-4">
      <button class="flex-1 py-3 text-[var(--terracotta)] border-b-2 border-[var(--terracotta)]">Proximos</button>
      <button class="flex-1 py-3 text-[var(--warm-brown)] hover:text-[var(--soft-black)]">Historico</button>
    </div>

    <!-- Booking Card -->
    <div class="bg-[var(--beige)] rounded-2xl p-4 shadow-[var(--shadow-card)] border border-[var(--sand)] flex flex-col gap-4">
      <div class="flex justify-between items-start">
        <div class="flex gap-3 items-center">
          <img src="https://images.unsplash.com/photo-1521590832167-7bfc1748fb43?q=80&w=100&auto=format&fit=crop" alt="Ana Silva" class="w-12 h-12 rounded-full object-cover" />
          <div>
            <h4 class="font-medium text-[var(--soft-black)]">Ana Silva</h4>
            <div class="text-xs px-2 py-0.5 mt-1 rounded bg-[var(--sand)]/30 text-[var(--olive)] font-medium inline-block">Confirmado</div>
          </div>
        </div>
        <div class="text-right">
          <p class="font-display font-semibold text-[var(--terracotta)] text-lg">14:30</p>
          <p class="text-xs text-[var(--warm-brown)]">Hoje, 24 Out</p>
        </div>
      </div>
      
      <div class="h-px bg-[var(--sand)] w-full"></div>
      
      <div>
        <h5 class="text-sm font-medium text-[var(--soft-black)]">Corte Feminino + Escova</h5>
        <div class="flex items-center gap-2 mt-1 text-xs text-[var(--warm-brown)]">
          <span>📍 No Domicilio</span>
          <span>•</span>
          <span>R$ 150</span>
        </div>
      </div>

      <div class="flex gap-2 mt-2">
        <a href="/Chat/1" class="flex-1 py-2 text-center rounded-lg border border-[var(--terracotta)] text-[var(--terracotta)] text-sm font-medium">Mensagem</a>
        <button class="flex-1 py-2 text-center rounded-lg border border-[var(--sand)] text-[var(--soft-black)] text-sm font-medium bg-[var(--off-white)]">Detalhes</button>
      </div>
    </div>
  </div>
</BaseLayout>
