---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="LOQK | Seja Profissional" 
  description="Cadastro de profissional na plataforma LOQK"
  showBottomNav={false}
>
  <div class="px-4 pt-12 pb-32">
    <header class="mb-8">
      <a href="javascript:history.back()" class="inline-block p-2 -ml-2 mb-4 text-[var(--soft-black)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
      <h1 class="text-3xl font-display text-[var(--soft-black)] mb-2">Seja um Profissional</h1>
      <p class="text-sm text-[var(--warm-brown)]">Preencha o formulario para passar pela nossa curadoria.</p>
    </header>

    <form class="flex flex-col gap-6" action="#">
      <div>
        <label class="block text-sm font-medium text-[var(--soft-black)] mb-1">Nome Completo</label>
        <input type="text" class="w-full bg-[var(--off-white)] border border-[var(--sand)] rounded-xl py-3 px-4 focus:outline-none focus:ring-1 focus:ring-[var(--terracotta)]" />
      </div>

      <div>
        <label class="block text-sm font-medium text-[var(--soft-black)] mb-1">Especialidade Principal</label>
        <select class="w-full bg-[var(--off-white)] border border-[var(--sand)] rounded-xl py-3 px-4 focus:outline-none focus:ring-1 focus:ring-[var(--terracotta)] appearance-none">
          <option>Cabelo</option>
          <option>Barba</option>
          <option>Maquiagem</option>
          <option>Estetica</option>
          <option>Unhas</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-[var(--soft-black)] mb-1">CPF ou CNPJ</label>
        <input type="text" class="w-full bg-[var(--off-white)] border border-[var(--sand)] rounded-xl py-3 px-4 focus:outline-none focus:ring-1 focus:ring-[var(--terracotta)]" />
      </div>

      <div>
        <label class="block text-sm font-medium text-[var(--soft-black)] mb-1">Link do Portfolio (Instagram, Site)</label>
        <input type="url" placeholder="https://" class="w-full bg-[var(--off-white)] border border-[var(--sand)] rounded-xl py-3 px-4 focus:outline-none focus:ring-1 focus:ring-[var(--terracotta)]" />
      </div>

      <div class="mt-4 p-4 rounded-xl border-2 border-dashed border-[var(--sand)] text-center flex flex-col items-center justify-center gap-2 bg-[var(--beige)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--warm-brown)]"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
        <p class="text-sm font-medium text-[var(--soft-black)]">Upload Documento com Foto</p>
        <p class="text-xs text-[var(--warm-brown)]">RG ou CNH (Max 5MB)</p>
        <input type="file" class="hidden" />
      </div>
    </form>
  </div>

  <div class="fixed bottom-0 left-0 right-0 bg-[var(--off-white)] border-t border-[var(--sand)] p-4 pb-safe shadow-[var(--shadow-card)] z-50">
    <button class="w-full bg-[var(--terracotta)] text-[var(--off-white)] px-8 py-4 rounded-xl font-medium shadow-[var(--shadow-soft)] hover:shadow-lg transition-transform active:scale-95 text-lg">
      Enviar para Analise
    </button>
  </div>
</BaseLayout>
