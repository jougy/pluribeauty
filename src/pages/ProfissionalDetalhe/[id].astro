---
import BaseLayout from '../../layouts/BaseLayout.astro';

// This is a dynamic route placeholder since Astro will match /[id]
export function getStaticPaths() {
  return [
    {params: {id: '1'}},
    {params: {id: '2'}},
    {params: {id: '3'}},
  ];
}

const { id } = Astro.params;

const prof = { 
  name: id === '2' ? 'Carlos Santos' : 'Ana Silva', 
  specialty: 'Cabelo, Maquiagem', 
  rating: 4.8, 
  reviews: 124, 
  image: 'https://images.unsplash.com/photo-1521590832167-7bfc1748fb43?q=80&w=600&auto=format&fit=crop',
  bio: 'Especialista em loiros e penteados para noivas com mais de 10 anos de experiencia.',
  services: [
    { id: 's1', name: 'Corte Feminino', duration: '60 min', price: 120 },
    { id: 's2', name: 'Coloracao', duration: '120 min', price: 250 },
    { id: 's3', name: 'Make Festa', duration: '90 min', price: 180 },
  ]
};
---

<BaseLayout 
  title={`LOQK | ${prof.name}`} 
  description={prof.bio}
  showBottomNav={false}
>
  <div class="pb-32">
    <!-- Header Image -->
    <div class="relative h-64 w-full">
      <img src={prof.image} alt={prof.name} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--soft-black)]/60 to-transparent"></div>
      
      <!-- Back Button -->
      <a href="/ListaProfissionais" class="absolute top-12 left-4 w-10 h-10 rounded-full bg-[var(--off-white)]/80 backdrop-blur flex items-center justify-center text-[var(--soft-black)] shadow-[var(--shadow-soft)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>

      <div class="absolute bottom-4 left-4 right-4 text-[var(--off-white)]">
        <h1 class="text-3xl font-display font-medium">{prof.name}</h1>
        <div class="flex items-center gap-2 text-sm opacity-90 mt-1">
          <span>{prof.specialty}</span>
          <span>•</span>
          <span class="text-yellow-400 font-medium">★ {prof.rating} ({prof.reviews})</span>
        </div>
      </div>
    </div>

    <!-- Tabs -->
    <div class="flex border-b border-[var(--sand)] px-4 mt-4 text-sm font-medium">
      <button class="flex-1 py-3 text-[var(--terracotta)] border-b-2 border-[var(--terracotta)]">Sobre</button>
      <button class="flex-1 py-3 text-[var(--warm-brown)] hover:text-[var(--soft-black)]">Servicos</button>
      <button class="flex-1 py-3 text-[var(--warm-brown)] hover:text-[var(--soft-black)]">Portfolio</button>
    </div>

    <!-- Content -->
    <div class="p-6">
      <h3 class="font-display text-xl mb-2 text-[var(--soft-black)]">Sobre</h3>
      <p class="text-[var(--warm-brown)] text-sm leading-relaxed mb-8">{prof.bio}</p>

      <h3 class="font-display text-xl mb-4 text-[var(--soft-black)]">Servicos Populares</h3>
      <div class="flex flex-col gap-4">
        {prof.services.map(s => (
          <div class="flex items-center justify-between p-4 rounded-xl border border-[var(--sand)] bg-[var(--off-white)]">
            <div>
              <h4 class="font-medium text-[var(--soft-black)]">{s.name}</h4>
              <p class="text-xs text-[var(--warm-brown)]">{s.duration}</p>
            </div>
            <div class="flex items-center gap-4">
              <span class="font-semibold text-[var(--terracotta)]">R$ {s.price}</span>
              <button class="w-8 h-8 rounded-full border border-[var(--terracotta)] text-[var(--terracotta)] flex items-center justify-center">+</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Floating Footer Action -->
  <div class="fixed bottom-0 left-0 right-0 bg-[var(--off-white)] border-t border-[var(--sand)] p-4 pb-safe shadow-[var(--shadow-card)] z-50">
    <div class="flex items-center justify-between gap-4">
      <div>
        <p class="text-xs text-[var(--warm-brown)]">Total</p>
        <p class="text-xl font-bold text-[var(--soft-black)]">R$ 0,00</p>
      </div>
      <a href="/Agendamento" class="bg-[var(--terracotta)] text-[var(--off-white)] px-8 py-3 rounded-xl font-medium shadow-[var(--shadow-soft)] hover:shadow-lg transition-transform active:scale-95">
        Agendar
      </a>
    </div>
  </div>
</BaseLayout>
