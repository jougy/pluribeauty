---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pagina nao encontrada - Pluri Beauty" description="Pagina nao encontrada.">
  <section class="min-h-[70vh] flex items-center justify-center bg-muted pt-24">
    <div class="text-center px-6">
      <h1 class="mb-4 text-6xl font-display font-bold">404</h1>
      <p class="mb-6 text-xl text-muted-foreground">Oops! Pagina nao encontrada.</p>
      <a href="/" class="btn-hero">Voltar para o inicio</a>
    </div>
  </section>
</BaseLayout>
