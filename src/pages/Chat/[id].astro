---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [
    {params: {id: '1'}},
  ];
}
---

<BaseLayout 
  title="LOQK | Chat" 
  description="Mensagens com o profissional"
  showBottomNav={false}
>
  <div class="flex flex-col h-screen bg-[var(--beige)]">
    <!-- Header -->
    <header class="flex items-center gap-4 p-4 bg-[var(--off-white)] border-b border-[var(--sand)] z-10 pt-safe">
      <a href="/Agenda" class="text-[var(--soft-black)] p-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
      <div class="flex gap-3 items-center">
        <img src="https://images.unsplash.com/photo-1521590832167-7bfc1748fb43?q=80&w=100&auto=format&fit=crop" alt="Ana Silva" class="w-10 h-10 rounded-full object-cover" />
        <div>
          <h2 class="font-medium text-[var(--soft-black)] leading-tight">Ana Silva</h2>
          <p class="text-[10px] text-[var(--olive)] font-medium">Online</p>
        </div>
      </div>
    </header>

    <!-- Messages -->
    <div class="flex-1 overflow-y-auto p-4 flex flex-col gap-4">
      <p class="text-xs text-center text-[var(--warm-brown)] my-2">Hoje</p>
      
      <div class="flex flex-col gap-1 items-start max-w-[85%]">
        <div class="bg-[var(--off-white)] border border-[var(--sand)] rounded-2xl p-3 rounded-tl-sm shadow-[var(--shadow-soft)]">
          <p class="text-sm text-[var(--soft-black)]">Ola! Tudo bem para hoje as 14:30?</p>
        </div>
        <span class="text-[10px] text-[var(--warm-brown)] ml-1">10:00</span>
      </div>

      <div class="flex flex-col gap-1 items-end self-end max-w-[85%]">
        <div class="bg-[var(--terracotta)] text-[var(--off-white)] rounded-2xl p-3 rounded-tr-sm shadow-[var(--shadow-soft)]">
          <p class="text-sm">Tudo otimo! O endereco e Av. Paulista, 1000 mesmo.</p>
        </div>
        <span class="text-[10px] text-[var(--warm-brown)] mr-1">10:05</span>
      </div>
    </div>

    <!-- Input Box -->
    <div class="bg-[var(--off-white)] border-t border-[var(--sand)] p-4 pb-safe flex gap-2">
      <button class="p-2 text-[var(--warm-brown)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
      </button>
      <input type="text" placeholder="Mensagem..." class="flex-1 bg-[var(--beige)] rounded-full px-4 py-2 border border-[var(--sand)] focus:outline-none focus:border-[var(--terracotta)]" />
      <button class="w-10 h-10 rounded-full bg-[var(--terracotta)] flex items-center justify-center text-[var(--off-white)] shadow-[var(--shadow-soft)] shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
      </button>
    </div>
  </div>
</BaseLayout>
