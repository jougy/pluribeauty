---
import BaseLayout from '../layouts/BaseLayout.astro';

const professionals = [
  { id: '1', name: 'Ana Silva', specialty: 'Cabelo & Maquiagem', rating: 4.8, distance: '2km', price: '$$', image: 'https://images.unsplash.com/photo-1521590832167-7bfc1748fb43?q=80&w=200&auto=format&fit=crop' },
  { id: '2', name: 'Carlos Santos', specialty: 'Barbearia', rating: 4.9, distance: '5km', price: '$', image: 'https://images.unsplash.com/photo-1503951914875-452162b0f3f1?q=80&w=200&auto=format&fit=crop' },
  { id: '3', name: 'Studio Bella', specialty: 'Unhas & Estetica', rating: 4.7, distance: '1km', price: '$$$', image: 'https://images.unsplash.com/photo-1522337660859-02fbefca4702?q=80&w=200&auto=format&fit=crop' }
];

const currentCategory = Astro.url.searchParams.get('category') || 'Todos';
---

<BaseLayout 
  title="LOQK | Profissionais" 
  description="Lista de profissionais de beleza"
>
  <div class="px-4 pt-12 flex flex-col gap-6">
    <header class="flex items-center gap-4">
      <a href="/Descobrir" class="p-2 -ml-2 text-[var(--soft-black)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
      <h1 class="text-2xl font-display text-[var(--soft-black)] capitalize">{currentCategory}</h1>
    </header>

    <!-- Filters -->
    <section class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide">
      <button class="px-4 py-2 rounded-full border border-[var(--terracotta)] text-[var(--terracotta)] bg-[var(--terracotta)]/10 text-sm font-medium whitespace-nowrap">Avaliacao 4.5+</button>
      <button class="px-4 py-2 rounded-full border border-[var(--sand)] text-[var(--soft-black)] text-sm font-medium bg-[var(--off-white)] whitespace-nowrap">Preco: $$</button>
      <button class="px-4 py-2 rounded-full border border-[var(--sand)] text-[var(--soft-black)] text-sm font-medium bg-[var(--off-white)] whitespace-nowrap">Ate 5km</button>
      <button class="px-4 py-2 rounded-full border border-[var(--sand)] text-[var(--soft-black)] text-sm font-medium bg-[var(--off-white)] whitespace-nowrap">Domicilio</button>
    </section>

    <!-- Grid -->
    <section class="flex flex-col gap-4">
      {professionals.map((prof) => (
        <a href={`/ProfissionalDetalhe/${prof.id}`} class="bg-[var(--beige)] rounded-2xl p-4 flex gap-4 items-center shadow-[var(--shadow-card)] border border-[var(--sand)] transition-transform hover:scale-[1.02]">
          <img src={prof.image} alt={prof.name} class="w-20 h-20 rounded-xl object-cover" />
          <div class="flex-1">
            <h4 class="font-display font-medium text-lg text-[var(--soft-black)]">{prof.name}</h4>
            <p class="text-sm text-[var(--warm-brown)]">{prof.specialty}</p>
            <div class="flex items-center gap-2 mt-2 text-xs text-[var(--olive)]">
              <span class="font-semibold">★ {prof.rating}</span>
              <span>•</span>
              <span class="text-[var(--warm-brown)]">📍 {prof.distance}</span>
              <span>•</span>
              <span class="text-[var(--terracotta)]">{prof.price}</span>
            </div>
          </div>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>
