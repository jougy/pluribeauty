---
const { currentPath } = Astro.props;

const navItems = [
  { name: 'Descobrir', path: '/Descobrir', icon: 'compass' },
  { name: 'Mapa', path: '/Mapa', icon: 'map-pin' },
  { name: 'Favoritos', path: '/Favoritos', icon: 'heart' },
  { name: 'Agenda', path: '/Agenda', icon: 'calendar' },
  { name: 'Perfil', path: '/Perfil', icon: 'user' },
];

const checkActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/');
---

<nav class="fixed bottom-0 left-0 right-0 bg-[var(--off-white)] border-t border-[var(--sand)] pb-safe z-50">
  <div class="flex justify-around items-center h-16 px-2">
    {navItems.map((item) => {
      const isActive = checkActive(item.path);
      return (
        <a 
          href={item.path} 
          class={`flex flex-col items-center justify-center w-full h-full space-y-1 transition-colors ${isActive ? 'text-[var(--terracotta)]' : 'text-[var(--sand)]'}`}
        >
          {/* Using Lucide-like SVG placeholders for icons based on item.icon name */}
          <div class="w-6 h-6 flex items-center justify-center relative">
            {isActive && (
              <span class="absolute -top-1 right-0 w-1.5 h-1.5 bg-[var(--terracotta)] rounded-full"></span>
            )}
            {item.icon === 'compass' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill={isActive ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
            )}
            {item.icon === 'map-pin' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill={isActive ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            )}
            {item.icon === 'heart' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill={isActive ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            )}
            {item.icon === 'calendar' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill={isActive ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
            )}
            {item.icon === 'user' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill={isActive ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            )}
          </div>
          <span class="text-[10px] font-medium">{item.name}</span>
        </a>
      );
    })}
  </div>
</nav>
