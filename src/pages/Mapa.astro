---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="LOQK | Mapa" 
  description="Mapa de profissionais"
>
  <div class="relative h-screen w-full flex flex-col bg-[var(--beige)]">
    <!-- Map UI Overlay placeholder -->
    <div class="absolute inset-0 z-0">
      <!-- Embedded static map image or interactive map component -->
      <img src="https://images.unsplash.com/photo-1524661135-423995f22d0b?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover opacity-60 mix-blend-multiply" alt="Map" />
      
      <!-- Pin -->
      <a href="/ProfissionalDetalhe/1" class="absolute top-[40%] left-[50%] -translate-x-1/2 -translate-y-1/2 group">
        <div class="bg-[var(--terracotta)] text-[var(--off-white)] px-3 py-1.5 rounded-full text-xs font-bold shadow-[var(--shadow-soft)] animate-bounce relative z-10">Ana S.</div>
        <div class="w-3 h-3 bg-[var(--terracotta)] rotate-45 absolute -bottom-1 left-1/2 -translate-x-1/2 z-0"></div>
      </a>
      
      <!-- Pin 2 -->
      <a href="/ProfissionalDetalhe/2" class="absolute top-[55%] left-[30%] -translate-x-1/2 -translate-y-1/2 group">
        <div class="bg-[var(--soft-black)] text-[var(--off-white)] px-3 py-1.5 rounded-full text-xs font-bold shadow-[var(--shadow-soft)] relative z-10">Carlos</div>
        <div class="w-3 h-3 bg-[var(--soft-black)] rotate-45 absolute -bottom-1 left-1/2 -translate-x-1/2 z-0"></div>
      </a>
    </div>

    <!-- UI Overlay (Header) -->
    <div class="absolute top-0 left-0 right-0 p-4 pt-12 bg-gradient-to-b from-[var(--off-white)] to-transparent z-10 pointer-events-none">
      <div class="pointer-events-auto">
        <div class="relative max-w-sm mx-auto shadow-[var(--shadow-soft)]">
          <input 
            type="text" 
            placeholder="Buscar no mapa..." 
            class="w-full bg-[var(--off-white)] border border-[var(--sand)] rounded-full py-3 px-4 focus:outline-none focus:ring-1 focus:ring-[var(--terracotta)]"
          />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
