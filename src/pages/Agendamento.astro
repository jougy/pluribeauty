---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="LOQK | Agendamento" 
  description="Agende seu servico de beleza"
  showBottomNav={false}
>
  <div class="px-4 pt-12 pb-32 flex flex-col h-screen">
    <header class="flex items-center gap-4 mb-8">
      <a href="javascript:history.back()" class="p-2 -ml-2 text-[var(--soft-black)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
      <h1 class="text-2xl font-display text-[var(--soft-black)]">Agendamento</h1>
    </header>

    <!-- Progress -->
    <div class="flex items-center gap-2 mb-8">
      <div class="h-1 flex-1 bg-[var(--terracotta)] rounded-full"></div>
      <div class="h-1 flex-1 bg-[var(--sand)] rounded-full"></div>
      <div class="h-1 flex-1 bg-[var(--sand)] rounded-full"></div>
    </div>

    <div class="flex-1">
      <h2 class="font-display text-xl mb-4 text-[var(--soft-black)]">Onde sera o atendimento?</h2>
      
      <div class="flex flex-col gap-4">
        <button class="flex items-start gap-4 p-4 rounded-2xl border-2 border-[var(--terracotta)] bg-[var(--terracotta)]/5 text-left transition-colors">
          <div class="w-12 h-12 rounded-full bg-[var(--off-white)] flex items-center justify-center text-[var(--terracotta)] shrink-0 shadow-[var(--shadow-soft)]">🏠</div>
          <div>
            <h3 class="font-medium text-[var(--soft-black)] text-lg">No Domicilio</h3>
            <p class="text-sm text-[var(--warm-brown)]">O profissional vai ate a sua localizacao. Taxas podem ser aplicadas.</p>
          </div>
        </button>

        <button class="flex items-start gap-4 p-4 rounded-2xl border border-[var(--sand)] bg-[var(--off-white)] text-left transition-colors hover:border-[var(--terracotta)]">
          <div class="w-12 h-12 rounded-full bg-[var(--beige)] flex items-center justify-center text-[var(--warm-brown)] shrink-0">🏪</div>
          <div>
            <h3 class="font-medium text-[var(--soft-black)] text-lg">No Salao / Estudio</h3>
            <p class="text-sm text-[var(--warm-brown)]">Voce ira ate o local de atendimento do profissional.</p>
          </div>
        </button>
      </div>

      <!-- Mock Address Field for Domicilio -->
      <div class="mt-8">
        <label class="block text-sm font-medium text-[var(--soft-black)] mb-2">Endereço para atendimento</label>
        <div class="relative">
          <input type="text" value="Av. Paulista, 1000 - Bela Vista" class="w-full bg-[var(--off-white)] border border-[var(--sand)] rounded-xl py-3 px-4 focus:outline-none focus:ring-1 focus:ring-[var(--terracotta)]" />
          <button class="absolute right-4 top-3 text-[var(--terracotta)] text-sm font-medium">Alterar</button>
        </div>
      </div>
    </div>

    <div class="pt-4 mt-auto border-t border-[var(--sand)] hidden lg:block"></div>
  </div>

  <div class="fixed bottom-0 left-0 right-0 bg-[var(--off-white)] border-t border-[var(--sand)] p-4 pb-safe shadow-[var(--shadow-card)] z-50">
    <button class="w-full bg-[var(--terracotta)] text-[var(--off-white)] px-8 py-4 rounded-xl font-medium shadow-[var(--shadow-soft)] hover:shadow-lg transition-transform active:scale-95 text-lg">
      Continuar
    </button>
  </div>
</BaseLayout>
